{
  "manifest_version": 3,
  "name": "Social Open Tracker",
  "version": "1.0.0",
  "description": "Tracks daily opens across selected social sites and shows a floating counter on each tracked site.",
  "permissions": [
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "https://facebook.com/*",
    "https://*.facebook.com/*",
    "https://instagram.com/*",
    "https://*.instagram.com/*",
    "https://linkedin.com/*",
    "https://*.linkedin.com/*",
    "https://x.com/*",
    "https://twitter.com/*",
    "https://*.twitter.com/*",
    "https://youtube.com/*",
    "https://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Social Open Tracker",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://facebook.com/*",
        "https://*.facebook.com/*",
        "https://instagram.com/*",
        "https://*.instagram.com/*",
        "https://linkedin.com/*",
        "https://*.linkedin.com/*",
        "https://x.com/*",
        "https://twitter.com/*",
        "https://*.twitter.com/*",
        "https://youtube.com/*",
        "https://*.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
